[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.7
reloadable = true

[libraries]
macos.debug = "res://../rust/target/debug/libplink.dylib"
macos.release = "res://../rust/target/release/libplink.dylib"
linux.debug.x86_64 = "res://../rust/target/debug/libplink.so"
linux.release.x86_64 = "res://../rust/target/release/libplink.so"
windows.debug.x86_64 = "res://../rust/target/debug/plink.dll"
windows.release.x86_64 = "res://../rust/target/release/plink.dll"
